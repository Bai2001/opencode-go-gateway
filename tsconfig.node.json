{
    "compilerOptions": {
        "composite": true,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "target": "ES2022",
        "lib": ["ES2022"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "types": ["node", "electron-vite/node"],
        "paths": {
            "@main/*": ["./src/main/*"],
            "@shared/*": ["./src/shared/*"]
        }
    },
    "include": [
        "src/main/**/*.ts",
        "src/preload/**/*.ts",
        "src/shared/**/*.ts",
        "electron.vite.config.ts"
    ]
}
